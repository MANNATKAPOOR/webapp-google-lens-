# Environment variables for AI Vision OCR Web App

# Hugging Face API Token (Get a free read token at https://huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE
# Backend settings
PORT=8000
ENVIRONMENT=development
ALLOWED_ORIGINS=*
MAX_IMAGE_SIZE_MB=10
# Path to Flutter Web build output (for serving frontend from backend)
FRONTEND_PATH=frontend_flutter/build/web
